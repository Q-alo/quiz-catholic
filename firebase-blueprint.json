{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "email": {
          "type": "string"
        },
        "lastLoginAt": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string"
        },
        "backupData": {
          "type": "string"
        },
        "storageUsedBytes": {
          "type": "number"
        },
        "dailyGeminiCalls": {
          "type": "number"
        },
        "recentApiTimestamps": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    }
  }
}
