rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isVerified() {
      // For Google login without strict email verification enforcing
      return true; 
    }

    function isValidUser(data) {
      return (
                (!('email' in data) || data.email == null || data.email is string) &&
                (!('lastLoginAt' in data) || data.lastLoginAt == null || data.lastLoginAt is string) &&
                (!('updatedAt' in data) || data.updatedAt == null || data.updatedAt is string) &&
                (!('backupData' in data) || data.backupData == null || data.backupData is string) &&
                (!('storageUsedBytes' in data) || data.storageUsedBytes == null || data.storageUsedBytes is number) &&
                (!('dailyGeminiCalls' in data) || data.dailyGeminiCalls == null || data.dailyGeminiCalls is number) &&
                (!('recentApiTimestamps' in data) || data.recentApiTimestamps == null || data.recentApiTimestamps is list)
             );
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId 
                    && isValidId(userId)
                    && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId
                    && isValidUser(incoming())
                    && incoming().diff(resource.data).affectedKeys().hasOnly([
                      'email', 'lastLoginAt', 'backupData', 'updatedAt', 
                      'storageUsedBytes', 'dailyGeminiCalls', 'recentApiTimestamps'
                    ]);
    }
    
    match /test/connection {
      allow read: if true;
    }

    match /stats/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() 
                            && isValidId(docId)
                            && (!('flash_lite' in incoming()) || incoming().flash_lite is number)
                            && (!('flash' in incoming()) || incoming().flash is number);
    }
  }
}
